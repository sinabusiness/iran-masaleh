rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default-deny catch-all as required by the Eight Pillars
    match /{document=**} {
      allow read, write: if false;
    }

    // Allow read/write access to the products collection
    match /products/{productId} {
      allow read, write: if true;
    }
  }
}
